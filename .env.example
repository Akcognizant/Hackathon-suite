# Environment variables for the Hackathon Suite (local dev template).
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# MUST NEVER be committed. In real deployments, provide these via your platform's
# secret manager / CI environment, not a file.

# --- PostgreSQL (both apps share the same local server) ---
DB_USERNAME=postgres
DB_PASSWORD=change-me-local-postgres-password

# --- JWT signing secrets ---
# Each app signs its own session tokens with JWT_SECRET.
# For the assessment -> hackathon SSO handoff to work, the assessment app's
# HACKATHON_JWT_SECRET must EXACTLY equal the hackathon app's JWT_SECRET.
# Use a long random value (>= 64 chars). Generate one with, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
HACKATHON_JWT_SECRET=change-me-to-the-same-value-as-hackathon-JWT_SECRET

# --- Anthropic (optional; AI submission scoring runs in mock mode without it) ---
ANTHROPIC_API_KEY=
